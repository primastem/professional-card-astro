---
//src/components/Card.astro
const {name, position, aboutMe, linkedin, github, cvLink, profileImage, mainLink, mainLinkText } = Astro.props;

import '../styles/card.css';
---

<div class="container">
    <div class="card-container">
        <div class="descripcion">
            <h1>{name}</h1>
            <h2>{position}</h2>
            <p>{aboutMe}</p>
            <div class="icons">
                <a href={linkedin} class="hover-text" target="_blank">
                    <span class="tooltip-text" id="fade">
                        LinkedIn
                    </span>
                    <i class="bi bi-linkedin"></i>
                </a>
                <a href={github} class="hover-text" target="_blank">
                    <span class="tooltip-text" id="fade">
                        GitHub
                    </span>
                    <i class="bi bi-github"></i>
                </a>
                <a href={cvLink} class="hover-text" target="_blank">
                    <span class="tooltip-text" id="fade">
                        Site officiel
                    </span>
                    <i class="bi bi-box-arrow-up-right"></i>
                </a>
            </div>
            {mainLink && (
                <a href={mainLink} class="main-cta" target="_blank">
                    {mainLinkText || "Visiter le site"}
                    <i class="bi bi-arrow-right"></i>
                </a>
            )}
        </div>
        <div class="image">
            <img src={profileImage} alt="">
        </div>
    </div>
</div>